# ============================================================
# Cloudflare / static-host cache rules
#
# Rule order: most-specific first.
# Cloudflare respects Cache-Control from origin; these headers
# are also used by Nginx/Caddy if serving directly.
# ============================================================

# --- Never cache the SW and the HTML shell ---
# These must always be re-fetched so the browser can detect a
# new service worker and new asset hashes.
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/workbox-*.js
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# Root path serves index.html — same rule
/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# --- Hashed assets: cache forever at the edge ---
# Vite appends a content hash to every JS/CSS bundle name.
# Safe to cache immutably because the filename changes on every build.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# --- Web manifest: must be served with correct content-type for PWA install ---
/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# --- Icons and other static assets: long cache, revalidate on change ---
/icons/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon.svg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
